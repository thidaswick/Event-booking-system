<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="https://jakarta.ee/xml/ns/jakartaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="https://jakarta.ee/xml/ns/jakartaee https://jakarta.ee/xml/ns/jakartaee/web-app_6_0.xsd"
         version="6.0">

    <display-name>Event Booking System</display-name>

    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Registration servlet is also registered by CustomerRegisterContextListener (Jetty dev robustness). -->
    <servlet>
        <servlet-name>CustomerRegisterServlet</servlet-name>
        <servlet-class>com.eventbooking.web.CustomerRegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CustomerRegisterServlet</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>

    <listener>
        <listener-class>com.eventbooking.web.CustomerRegisterContextListener</listener-class>
    </listener>

    <!-- Contact CRUD (web.xml + ContactServletContextListener for Jetty dev reliability). -->
    <servlet>
        <servlet-name>ContactListServlet</servlet-name>
        <servlet-class>com.eventbooking.web.ContactListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ContactListServlet</servlet-name>
        <url-pattern>/contacts/list</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ContactCreateServlet</servlet-name>
        <servlet-class>com.eventbooking.web.ContactCreateServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ContactCreateServlet</servlet-name>
        <url-pattern>/contacts/create</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ContactEditServlet</servlet-name>
        <servlet-class>com.eventbooking.web.ContactEditServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ContactEditServlet</servlet-name>
        <url-pattern>/contacts/edit</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>ContactDeleteServlet</servlet-name>
        <servlet-class>com.eventbooking.web.ContactDeleteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ContactDeleteServlet</servlet-name>
        <url-pattern>/contacts/delete</url-pattern>
    </servlet-mapping>

    <listener>
        <listener-class>com.eventbooking.web.ContactServletContextListener</listener-class>
    </listener>

    <!-- Customer accounts CRUD (customers.txt — same file pattern as bookings). -->
    <servlet>
        <servlet-name>CustomerListServlet</servlet-name>
        <servlet-class>com.eventbooking.web.CustomerListServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CustomerListServlet</servlet-name>
        <url-pattern>/customers/list</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>CustomerEditServlet</servlet-name>
        <servlet-class>com.eventbooking.web.CustomerEditServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CustomerEditServlet</servlet-name>
        <url-pattern>/customers/edit</url-pattern>
    </servlet-mapping>
    <servlet>
        <servlet-name>CustomerDeleteServlet</servlet-name>
        <servlet-class>com.eventbooking.web.CustomerDeleteServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CustomerDeleteServlet</servlet-name>
        <url-pattern>/customers/delete</url-pattern>
    </servlet-mapping>

    <listener>
        <listener-class>com.eventbooking.web.CustomerServletContextListener</listener-class>
    </listener>

    <!-- Other servlets use @WebServlet; this file documents mappings for the assignment. -->
</web-app>
